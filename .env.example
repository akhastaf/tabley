NODE_ENV=development

# Postgres (matches docker-compose service "postgres", host port 5440)
DATABASE_URL=postgresql://postgres:postgres@localhost:5440/tabley

# Redis (matches docker-compose service "redis", host port 6390)
REDIS_URL=redis://localhost:6390

# Meilisearch (matches docker-compose service "meilisearch", host port 7740)
MEILI_HOST=http://localhost:7740
MEILI_MASTER_KEY=masterKeyDevOnly_changeMe

# Better Auth — generate a long random secret for production
BETTER_AUTH_SECRET=replace-with-32+char-random-string-please-change
BETTER_AUTH_URL=http://localhost:3011

# Resend email
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=no-reply@tabley.local

# API
API_PORT=3011
API_CORS_ORIGIN=http://localhost:3010

# Web (Next.js public envs)
NEXT_PUBLIC_API_URL=http://localhost:3011
NEXT_PUBLIC_APP_URL=http://localhost:3010

# SaaS bootstrap admin (used by seed)
ADMIN_EMAIL=admin@tabley.local
ADMIN_PASSWORD=ChangeMe!2026
ADMIN_NAME=Tabley Admin

# AI provider for menu ingestion (pick one and fill)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
